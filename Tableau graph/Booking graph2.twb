    <worksheet name='Net ADR Comparison'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Net ADR Comparison</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='fact_booking+ (data)' name='federated.0iio7wz0azduz60ziqu6h08nmyu7' />
          </datasources>
          <datasource-dependencies datasource='federated.0iio7wz0azduz60ziqu6h08nmyu7'>
            <column caption='Gross ADR' datatype='real' name='[Calculation_0759001505918976]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([gross_room_revenue]) / SUM([number_of_rooms])' />
            </column>
            <column caption='Net ADR' datatype='real' name='[Calculation_0759001506070529]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([net_room_revenue]) / SUM([number_of_rooms])' />
            </column>
            <column caption='Channel Name' datatype='string' name='[channel_name]' role='dimension' type='nominal' />
            <column caption='Gross Room Revenue' datatype='integer' name='[gross_room_revenue]' role='measure' type='quantitative' />
            <column caption='Net Room Revenue' datatype='real' name='[net_room_revenue]' role='measure' type='quantitative' />
            <column-instance column='[channel_name]' derivation='None' name='[none:channel_name:nk]' pivot='key' type='nominal' />
            <column-instance column='[status]' derivation='None' name='[none:status:nk]' pivot='key' type='nominal' />
            <column caption='Number Of Rooms' datatype='integer' name='[number_of_rooms]' role='measure' type='quantitative' />
            <column caption='Status' datatype='string' name='[status]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_0759001505918976]' derivation='User' name='[usr:Calculation_0759001505918976:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0759001506070529]' derivation='User' name='[usr:Calculation_0759001506070529:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0iio7wz0azduz60ziqu6h08nmyu7].[:Measure Names]'>
            <groupfilter function='union' user:op='manual'>
              <groupfilter function='member' level='[:Measure Names]' member='&quot;[federated.0iio7wz0azduz60ziqu6h08nmyu7].[usr:Calculation_0759001505918976:qk]&quot;' />
              <groupfilter function='member' level='[:Measure Names]' member='&quot;[federated.0iio7wz0azduz60ziqu6h08nmyu7].[usr:Calculation_0759001506070529:qk]&quot;' />
